# Copy to .env.local and fill in real values. Never commit .env.local.

# Tavily API key — crawls the news sources (https://tavily.com)
TAVILY_API_KEY=

# Nebius API key — LLM synthesis (https://tokenfactory.nebius.com)
NEBIUS_API_KEY=

# Upstash Redis REST credentials — auto-wired by Vercel Marketplace in prod
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared secret guarding /api/refresh (e.g. `openssl rand -hex 32`)
CRON_SECRET=

# Optional — Nebius model ID override. Default: Qwen/Qwen3.5-397B-A17B-fast
# NEBIUS_MODEL=
